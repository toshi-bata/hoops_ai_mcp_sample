# HOOPS AI License key (required)
HOOPS_AI_LICENSE=your-license-key-here

# Absolute path to the HOOPS AI notebooks directory
# (the directory that contains the "out/" folder produced by the ETL notebooks)
HOOPS_AI_SDK_DIR=C:/SDK/HOOPS_AI/V1.1

# Filename of the trained MFR model checkpoint
# (located at <HOOPS_AI_SDK_DIR>/packages/trained_ml_models/<name>)
HOOPS_AI_MFR_MODEL_NAME=ts3d_162k_mfr.ckpt
